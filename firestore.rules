rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // All client reads/writes are blocked. The Firebase Admin SDK, used by
    // the Vercel serverless functions in api/submitIntake.js and
    // api/getSubmissions.js (authenticated via a service account), bypasses
    // these rules entirely, so those two functions can still write/read.
    // The public form and admin page never talk to Firestore directly.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
